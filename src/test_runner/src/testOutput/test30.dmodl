	// Generator 5 (bus 11) - Standard
	Pg_5 = 0.000000; Vs_5 = 1.082000; mBase_5 = 100.0
	xd_prime_5 = 0.110000; H_5 = 4.000000; D_5 = 0.000000
	Omega_b_5 = 314.159000; E_prime_5 = 1.082000
	P_m_5 = 0.000000
	Vm_5 = 1.082000
	P_e_5 = 0 [out=true]

	// Generator 6 (bus 13) - Standard
	Pg_6 = 0.000000; Vs_6 = 1.071000; mBase_6 = 100.0
	xd_prime_6 = 0.135000; H_6 = 5.000000; D_6 = 0.000000
	Omega_b_6 = 314.159000; E_prime_6 = 1.071000
	P_m_6 = 0.000000
	Vm_6 = 1.071000
	P_e_6 = 0 [out=true]

ODEs:
	// -- Standard synchronous generator equations --
	delta_1' = Omega_b_1 * (omega_1 - 1)
	omega_1' = (P_m_1 - (E_prime_1*Vm_1/xd_prime_1)*sin(delta_1) - D_1*(omega_1-1)) / (2*H_1)

	delta_3' = Omega_b_3 * (omega_3 - 1)
	omega_3' = (P_m_3 - (E_prime_3*Vm_3/xd_prime_3)*sin(delta_3) - D_3*(omega_3-1)) / (2*H_3)

	delta_4' = Omega_b_4 * (omega_4 - 1)
	omega_4' = (P_m_4 - (E_prime_4*Vm_4/xd_prime_4)*sin(delta_4) - D_4*(omega_4-1)) / (2*H_4)

	delta_5' = Omega_b_5 * (omega_5 - 1)
	omega_5' = (P_m_5 - (E_prime_5*Vm_5/xd_prime_5)*sin(delta_5) - D_5*(omega_5-1)) / (2*H_5)

	delta_6' = Omega_b_6 * (omega_6 - 1)
	omega_6' = (P_m_6 - (E_prime_6*Vm_6/xd_prime_6)*sin(delta_6) - D_6*(omega_6-1)) / (2*H_6)

	// -- DFIG generator equations (Milano model) --
	// DFIG Generator 2 at bus 2
	omega_m_2' = (P_opt_2/omega_m_2 - (-(xmu_2*v_h_2*i_rq_2)/(Omega_b_2*(xs_2+xmu_2)))) / (2*H_total_2)
	i_rq_2' = (1/T_eps_2) * (-((xs_2+xmu_2)/(xmu_2*v_h_2))*(P_opt_2/omega_m_2) - i_rq_2)
	i_rd_2' = K_V_2*(v_h_2-v_ref_2) - (v_h_2/xmu_2) - i_rd_2

PostProc:
	P_e_1 = (E_prime_1*Vm_1/xd_prime_1)*sin(delta_1)
	P_h_2 = -(xmu_2*v_h_2*i_rq_2)/(xs_2+xmu_2)
	Q_h_2 = -((xmu_2*v_h_2*i_rd_2)/(xs_2+xmu_2)) - (v_h_2*v_h_2/xmu_2)
	P_e_3 = (E_prime_3*Vm_3/xd_prime_3)*sin(delta_3)
	P_e_4 = (E_prime_4*Vm_4/xd_prime_4)*sin(delta_4)
	P_e_5 = (E_prime_5*Vm_5/xd_prime_5)*sin(delta_5)
	P_e_6 = (E_prime_6*Vm_6/xd_prime_6)*sin(delta_6)
end
