Params:
	baseMVA = 100.0
	// Generator 1 (bus 1) - Standard
	Pg_1 = 2.602000; Vs_1 = 1.060000; mBase_1 = 100.0
	xd_prime_1 = 0.060800; H_1 = 23.640000; D_1 = 0.000000
	Omega_b_1 = 314.159000; E_prime_1 = 1.060000
