Header:
	startTime = 0
	dTime = 0.001000
	endTime = 30.000
	maxIter = 20
	report = Solved
end
//Model generated by Vjetroelektrana DFIG plugin converter

Model [type=DAE domain=real method=RK2 name="Vjetroelektrana DFIG Power System"]:
Vars [out=true]:
	delta_1=0.039627	// rotor angle [rad]
	omega_1=1.000000	// rotor speed [p.u.]
	omega_m_2=1.012000	// DFIG rotor speed [p.u.]
	i_rq_2=-0.240000	// DFIG q-axis rotor current
	i_rd_2=0.020000	// DFIG d-axis rotor current
	delta_3=0.143653	// rotor angle [rad]
	omega_3=1.000000	// rotor speed [p.u.]

Params:
	baseMVA = 100.0
	// Generator 1 (bus 1) - Standard
	Pg_1 = 0.716000; Vs_1 = 1.040000; mBase_1 = 247.5
	xd_prime_1 = 0.060800; H_1 = 23.640000; D_1 = 0.000000
	Omega_b_1 = 314.159000; E_prime_1 = 1.056600
	P_m_1 = 0.716000
	Vm_1 = 1.040000
	P_e_1 = 0 [out=true]

	// Generator 2 (bus 2) - DFIG
	Pg_2 = 1.630000; Vs_2 = 1.025000; mBase_2 = 192.0
	xs_2 = 0.010000; xmu_2 = 3.500000
	H_total_2 = 3.500000; T_eps_2 = 0.010000
	K_V_2 = 10.000000; v_ref_2 = 1.025000
	P_opt_2 = 0.850000; Omega_b_2 = 314.159000
	v_h_2 = 1.025000
	P_h_2 = 0 [out=true]
	Q_h_2 = 0 [out=true]

	// Generator 3 (bus 3) - Standard
	Pg_3 = 0.850000; Vs_3 = 1.025000; mBase_3 = 128.0
	xd_prime_3 = 0.181300; H_3 = 6.400000; D_3 = 0.000000
	Omega_b_3 = 314.159000; E_prime_3 = 1.050200
	P_m_3 = 0.850000
	Vm_3 = 1.025000
	P_e_3 = 0 [out=true]

ODEs:
	// -- Standard synchronous generator equations --
	delta_1' = Omega_b_1 * (omega_1 - 1)
	omega_1' = (P_m_1 - (E_prime_1*Vm_1/xd_prime_1)*sin(delta_1) - D_1*(omega_1-1)) / (2*H_1)

	delta_3' = Omega_b_3 * (omega_3 - 1)
	omega_3' = (P_m_3 - (E_prime_3*Vm_3/xd_prime_3)*sin(delta_3) - D_3*(omega_3-1)) / (2*H_3)

	// -- DFIG generator equations (Milano model) --
	// DFIG Generator 2 at bus 2
	omega_m_2' = (P_opt_2/omega_m_2 - (-(xmu_2*v_h_2*i_rq_2)/(Omega_b_2*(xs_2+xmu_2)))) / (2*H_total_2)
	i_rq_2' = (1/T_eps_2) * (-((xs_2+xmu_2)/(xmu_2*v_h_2))*(P_opt_2/omega_m_2) - i_rq_2)
	i_rd_2' = K_V_2*(v_h_2-v_ref_2) - (v_h_2/xmu_2) - i_rd_2

PostProc:
	P_e_1 = (E_prime_1*Vm_1/xd_prime_1)*sin(delta_1)
	P_h_2 = -(xmu_2*v_h_2*i_rq_2)/(xs_2+xmu_2)
	Q_h_2 = -((xmu_2*v_h_2*i_rd_2)/(xs_2+xmu_2)) - (v_h_2*v_h_2/xmu_2)
	P_e_3 = (E_prime_3*Vm_3/xd_prime_3)*sin(delta_3)
end
