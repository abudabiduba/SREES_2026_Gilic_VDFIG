Header:
	newTab = false
	drawPlots = true
end
Model [name="Vjetroelektrana DFIG — Visualization"]:
Plots [backColor=auto]:
	linePlot [xLabel="Time [s]" yLabel="omega_m [p.u.]" name="DFIG Rotor Speed" anchor=TR legend=true nCols=1 anchorX=140 anchorY=35]:
		@x << t
		@y << omega_m_2 [colorD=red width=2 name="omega_m_2"]
	end
	linePlot [xLabel="Time [s]" yLabel="P_h [p.u.]" name="DFIG Active Power" anchor=TR legend=true nCols=1 anchorX=140 anchorY=35]:
		@x << t
		@y << P_h_2 [colorD=red width=2 name="P_h_2"]
	end
	linePlot [xLabel="Time [s]" yLabel="Q_h [p.u.]" name="DFIG Reactive Power" anchor=TR legend=true nCols=1 anchorX=140 anchorY=35]:
		@x << t
		@y << Q_h_2 [colorD=red width=2 name="Q_h_2"]
	end
	linePlot [xLabel="Time [s]" yLabel="I_rotor [p.u.]" name="DFIG Rotor Currents" anchor=TR legend=true nCols=1 anchorX=160 anchorY=35]:
		@x << t
		@y << i_rq_2 [colorD=red width=2 name="i_rq_2"]
		@y << i_rd_2 [colorD=lightBlue width=1 name="i_rd_2"]
	end
	linePlot [xLabel="Time [s]" yLabel="delta [rad]" name="Std Gen Rotor Angle" anchor=TR legend=true nCols=1 anchorX=140 anchorY=35]:
		@x << t
		@y << delta_1 [colorD=red width=2 name="delta_1"]
		@y << delta_3 [colorD=green width=2 name="delta_3"]
	end
	linePlot [xLabel="Time [s]" yLabel="omega [p.u.]" name="Std Gen Rotor Speed" anchor=TR legend=true nCols=1 anchorX=140 anchorY=35]:
		@x << t
		@y << omega_1 [colorD=red width=2 name="omega_1"]
		@y << omega_3 [colorD=green width=2 name="omega_3"]
	end
end //end of the visual model
